# dart-rtp-recorder — example environment file.
# Copy to `.env` and adjust values for your deployment.

# --- HTTP control API ---
HTTP_SERVER_ADDRESS=0.0.0.0
HTTP_SERVER_PORT=8080

# Directory where recordings are written. Must be writable by the process.
AUDIO_PATH=./recordings

# --- Recorder ---
# Recording codec/container to use.
#   pcm   — 16-bit PCM WAV, 8 kHz mono           (Phase 1; current default)
#   alaw  — G.711 a-law WAV, 8 kHz mono, 8-bit   (Phase 2; ~50% smaller)
#   mulaw — G.711 mu-law WAV, 8 kHz mono, 8-bit  (Phase 2; ~50% smaller)
#   opus  — Opus in Ogg                          (Phase 3 — not yet available)
#
# Choose alaw/mulaw to match the RTP payload type your PBX sends
# (PT=8 → alaw, PT=0 → mulaw). Mismatches are logged but not corrected.
RECORDER_CODEC=pcm

# Seconds of RTP silence after which an in-flight recording is auto-finalized.
# Callers that hit POST /stop?filename=... do not depend on this timeout.
RECORDER_IDLE_TIMEOUT_SECONDS=60

# --- Playback cache (Option A + Option B) ---
# GET /playback?filename=X always returns a browser-playable PCM WAV.
# For G.711 sources this is decoded on the fly. When caching is enabled,
# the first request also spawns a background full-file transcode written
# to PLAYBACK_CACHE_PATH so subsequent requests are served with sendfile
# (Range-aware, ~zero CPU). Per-request opt-out: ?cache=0.
PLAYBACK_CACHE_ENABLED=true
PLAYBACK_CACHE_PATH=./recordings/.pcm-cache

# --- Asterisk database (used to persist recording metadata) ---
AST_DB_HOST=localhost
AST_DB_PORT=3306
AST_DB_DATABASE=asterisk
AST_DB_USERNAME=asterisk
AST_DB_PASSWORD=changeme
